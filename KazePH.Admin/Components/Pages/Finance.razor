@page "/admin/finance"
@rendermode InteractiveServer
@inject KazeDbContext Db
@inject IConfiguration Configuration

@using KazePH.Core.Enums
@using Microsoft.EntityFrameworkCore

<PageTitle>Finance – KazePH Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart-fill me-2 text-success"></i>Finance Overview</h4>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

<!-- Period Filter -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    @foreach (var p in new[] { "Today", "This Week", "This Month", "All Time" })
    {
        <button class="btn btn-sm @(_period == p ? "btn-primary" : "btn-outline-secondary")"
                @onclick="() => SetPeriod(p)">@p</button>
    }
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else
{
    <!-- ── Row 1: Money In / Out ──────────────────────────────────────────────── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0" style="background:#12122a;border-left:3px solid #28a745 !important">
                <div class="card-body">
                    <div class="text-muted small mb-1"><i class="bi bi-arrow-down-circle me-1 text-success"></i>Total Deposited</div>
                    <div class="fs-4 fw-bold text-success">₱@_totalDeposited.ToString("N2")</div>
                    <div class="text-muted" style="font-size:0.72rem">@_depositCount approved deposits</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0" style="background:#12122a;border-left:3px solid #dc3545 !important">
                <div class="card-body">
                    <div class="text-muted small mb-1"><i class="bi bi-arrow-up-circle me-1 text-danger"></i>Total Paid Out</div>
                    <div class="fs-4 fw-bold text-danger">₱@_totalPaidOut.ToString("N2")</div>
                    <div class="text-muted" style="font-size:0.72rem">@_withdrawalCount completed withdrawals</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0" style="background:#12122a;border-left:3px solid #ffc107 !important">
                <div class="card-body">
                    <div class="text-muted small mb-1"><i class="bi bi-graph-up-arrow me-1 text-warning"></i>Platform Revenue</div>
                    <div class="fs-4 fw-bold text-warning">₱@_platformFees.ToString("N2")</div>
                    <div class="text-muted" style="font-size:0.72rem">Fees from withdrawals</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0" style="background:#12122a;border-left:3px solid #0dcaf0 !important">
                <div class="card-body">
                    <div class="text-muted small mb-1"><i class="bi bi-heart-fill me-1 text-info"></i>Total Agent Tips</div>
                    <div class="fs-4 fw-bold text-info">₱@_totalTips.ToString("N2")</div>
                    <div class="text-muted" style="font-size:0.72rem">Across all agents</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Row 2: Current Float ───────────────────────────────────────────────── -->
    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.72rem;letter-spacing:.08em">
        Current User Float (live, period-independent)
    </h6>
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0" style="background:#0f0f1e">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">Available in Wallets</div>
                    <div class="fs-5 fw-bold text-success">₱@_floatAvailable.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0" style="background:#0f0f1e">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">Locked in Bets</div>
                    <div class="fs-5 fw-bold text-warning">₱@_floatLocked.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0" style="background:#0f0f1e">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">Pending Withdrawal</div>
                    <div class="fs-5 fw-bold text-secondary">₱@_floatPendingWithdrawal.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0" style="background:#0f0f1e">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">Total User Float</div>
                    <div class="fs-5 fw-bold">₱@(_floatAvailable + _floatLocked + _floatPendingWithdrawal).ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Row 3: Pending Alerts ──────────────────────────────────────────────── -->
    @if (_pendingDepositAmount > 0 || _pendingWithdrawalAmount > 0)
    {
        <div class="row g-3 mb-4">
            @if (_pendingDepositAmount > 0)
            {
                <div class="col-12 col-md-6">
                    <div class="alert alert-warning mb-0 py-2">
                        <i class="bi bi-hourglass-split me-2"></i>
                        <strong>@_pendingDepositCount</strong> pending deposit(s) totalling
                        <strong>₱@_pendingDepositAmount.ToString("N2")</strong> awaiting approval
                    </div>
                </div>
            }
            @if (_pendingWithdrawalAmount > 0)
            {
                <div class="col-12 col-md-6">
                    <div class="alert alert-info mb-0 py-2">
                        <i class="bi bi-clock me-2"></i>
                        <strong>@_pendingWithdrawalCount</strong> pending withdrawal(s) totalling
                        <strong>₱@_pendingWithdrawalAmount.ToString("N2")</strong> to be processed
                    </div>
                </div>
            }
        </div>
    }

    <!-- ── Cash Flow by Payment Method ───────────────────────────────────────── -->
    <h6 class="fw-semibold mb-3">Cash Flow by Payment Method</h6>
    <div class="table-responsive mb-4">
        <table class="table table-dark align-middle mb-0">
            <thead>
                <tr class="text-muted small">
                    <th>Method</th>
                    <th class="text-success">Deposited In</th>
                    <th class="text-danger">Paid Out (Net)</th>
                    <th class="text-warning">Fees Kept</th>
                    <th class="text-info">Tips</th>
                    <th>Net Platform Position</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _byMethod)
                {
                    <tr>
                        <td>
                            <i class="bi @MethodIcon(row.Method) me-2"></i>
                            <span class="fw-semibold">@row.Method</span>
                        </td>
                        <td class="text-success">₱@row.Deposited.ToString("N2")</td>
                        <td class="text-danger">₱@row.PaidOut.ToString("N2")</td>
                        <td class="text-warning">₱@row.Fees.ToString("N2")</td>
                        <td class="text-info">₱@row.Tips.ToString("N2")</td>
                        <td>
                            @{var pos = row.Deposited - row.PaidOut; }
                            <span class="fw-bold @(pos >= 0 ? "text-success" : "text-danger")">
                                ₱@pos.ToString("N2")
                            </span>
                        </td>
                    </tr>
                }
                @if (_byMethod.Any())
                {
                    <tr class="fw-bold border-top border-secondary" style="background:#0f0f1e">
                        <td>Total</td>
                        <td class="text-success">₱@_byMethod.Sum(r => r.Deposited).ToString("N2")</td>
                        <td class="text-danger">₱@_byMethod.Sum(r => r.PaidOut).ToString("N2")</td>
                        <td class="text-warning">₱@_byMethod.Sum(r => r.Fees).ToString("N2")</td>
                        <td class="text-info">₱@_byMethod.Sum(r => r.Tips).ToString("N2")</td>
                        <td>
                            @{var totalPos = _byMethod.Sum(r => r.Deposited) - _byMethod.Sum(r => r.PaidOut); }
                            <span class="@(totalPos >= 0 ? "text-success" : "text-danger")">₱@totalPos.ToString("N2")</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ── Agent Tips Breakdown ───────────────────────────────────────────────── -->
    @if (_agentTips.Any())
    {
        <h6 class="fw-semibold mb-3"><i class="bi bi-heart-fill text-danger me-1"></i>Agent Tips Breakdown</h6>
        <div class="table-responsive mb-4">
            <table class="table table-dark align-middle mb-0">
                <thead>
                    <tr class="text-muted small">
                        <th>Agent</th>
                        <th>Withdrawals Processed</th>
                        <th class="text-info">Total Tips Earned</th>
                        <th>Avg Tip / Payout</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _agentTips.OrderByDescending(a => a.TotalTips))
                    {
                        <tr>
                            <td><i class="bi bi-person-fill me-2 text-muted"></i>@a.AgentUsername</td>
                            <td>@a.Count</td>
                            <td class="fw-bold text-info">₱@a.TotalTips.ToString("N2")</td>
                            <td class="text-muted">₱@(a.Count > 0 ? (a.TotalTips / a.Count).ToString("N2") : "0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- ── Recent Completed Transactions ────────────────────────────────────── -->
    <h6 class="fw-semibold mb-3">Recent Completed Withdrawals</h6>
    @if (_recentWithdrawals.Count == 0)
    {
        <div class="text-center text-muted py-4"><i class="bi bi-inbox fs-2 d-block mb-2"></i>No completed withdrawals yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-sm align-middle mb-0">
                <thead>
                    <tr class="text-muted small">
                        <th>Date</th>
                        <th>User</th>
                        <th>Method</th>
                        <th>Net Sent</th>
                        <th>Fee</th>
                        <th>Tip</th>
                        <th>Agent</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in _recentWithdrawals)
                    {
                        <tr>
                            <td class="text-muted small">@w.ProcessedAt?.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                            <td class="small">@(w.User?.Username ?? w.UserId[..8])</td>
                            <td><span class="badge bg-secondary">@w.PaymentMethod</span></td>
                            <td class="text-success fw-semibold">₱@w.NetAmount.ToString("N2")</td>
                            <td class="text-warning small">₱@w.Fee.ToString("N2")</td>
                            <td>
                                @if (w.AgentTip > 0)
                                {<span class="text-info small">₱@w.AgentTip.ToString("N2")</span>}
                                else
                                {<span class="text-muted small">—</span>}
                            </td>
                            <td class="text-muted small">@(w.ProcessedByUsername ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    // ── Period ───────────────────────────────────────────────────────────────
    private string _period = "This Month";
    private bool _loading = true;

    // ── Summary ──────────────────────────────────────────────────────────────
    private decimal _totalDeposited;
    private int     _depositCount;
    private decimal _totalPaidOut;
    private int     _withdrawalCount;
    private decimal _platformFees;
    private decimal _totalTips;

    // ── Float (live) ─────────────────────────────────────────────────────────
    private decimal _floatAvailable;
    private decimal _floatLocked;
    private decimal _floatPendingWithdrawal;

    // ── Pending ───────────────────────────────────────────────────────────────
    private decimal _pendingDepositAmount;
    private int     _pendingDepositCount;
    private decimal _pendingWithdrawalAmount;
    private int     _pendingWithdrawalCount;

    // ── Breakdowns ────────────────────────────────────────────────────────────
    private List<MethodRow>  _byMethod     = new();
    private List<AgentRow>   _agentTips    = new();
    private List<WithdrawalRequest> _recentWithdrawals = new();

    private record MethodRow(PaymentMethod Method, decimal Deposited, decimal PaidOut, decimal Fees, decimal Tips);
    private record AgentRow(string AgentUsername, int Count, decimal TotalTips);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task SetPeriod(string p)
    {
        _period = p;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        var (from, to) = GetRange();

        // ── Approved deposits in period ───────────────────────────────────────
        var deposits = await Db.TopUpRequests
            .Where(r => r.Status == TopUpStatus.Approved
                     && r.ReviewedAt >= from && r.ReviewedAt <= to)
            .ToListAsync();
        _totalDeposited = deposits.Sum(r => r.Amount);
        _depositCount   = deposits.Count;

        // ── Completed withdrawals in period ───────────────────────────────────
        var withdrawals = await Db.WithdrawalRequests
            .Include(r => r.User)
            .Where(r => r.Status == WithdrawalStatus.Completed
                     && r.ProcessedAt >= from && r.ProcessedAt <= to)
            .OrderByDescending(r => r.ProcessedAt)
            .ToListAsync();
        _totalPaidOut    = withdrawals.Sum(r => r.NetAmount);
        _withdrawalCount = withdrawals.Count;
        _platformFees    = withdrawals.Sum(r => r.Fee);
        _totalTips       = withdrawals.Sum(r => r.AgentTip);

        // ── Float: current wallet totals (no period filter) ───────────────────
        var wallets = await Db.Wallets.ToListAsync();
        _floatAvailable          = wallets.Sum(w => w.AvailableBalance);
        _floatLocked             = wallets.Sum(w => w.LockedBalance);
        _floatPendingWithdrawal  = wallets.Sum(w => w.PendingWithdrawalBalance);

        // ── Pending items ─────────────────────────────────────────────────────
        var pendingDeposits = await Db.TopUpRequests
            .Where(r => r.Status == TopUpStatus.Pending).ToListAsync();
        _pendingDepositAmount = pendingDeposits.Sum(r => r.Amount);
        _pendingDepositCount  = pendingDeposits.Count;

        var pendingWithdrawals = await Db.WithdrawalRequests
            .Where(r => r.Status == WithdrawalStatus.Pending || r.Status == WithdrawalStatus.Processing)
            .ToListAsync();
        _pendingWithdrawalAmount = pendingWithdrawals.Sum(r => r.Amount);
        _pendingWithdrawalCount  = pendingWithdrawals.Count;

        // ── By payment method ─────────────────────────────────────────────────
        var methods = Enum.GetValues<PaymentMethod>();
        _byMethod = methods.Select(m => new MethodRow(
            m,
            deposits.Where(d => d.PaymentMethod == m).Sum(d => d.Amount),
            withdrawals.Where(w => w.PaymentMethod == m).Sum(w => w.NetAmount),
            withdrawals.Where(w => w.PaymentMethod == m).Sum(w => w.Fee),
            withdrawals.Where(w => w.PaymentMethod == m).Sum(w => w.AgentTip)
        )).Where(r => r.Deposited > 0 || r.PaidOut > 0 || r.Fees > 0).ToList();

        // ── Agent tips breakdown ──────────────────────────────────────────────
        _agentTips = withdrawals
            .Where(w => w.AgentTip > 0 && !string.IsNullOrEmpty(w.ProcessedByUsername))
            .GroupBy(w => w.ProcessedByUsername!)
            .Select(g => new AgentRow(g.Key, g.Count(), g.Sum(w => w.AgentTip)))
            .ToList();

        // ── Recent completed withdrawals (last 20) ────────────────────────────
        _recentWithdrawals = withdrawals.Take(20).ToList();

        _loading = false;
    }

    private (DateTime from, DateTime to) GetRange()
    {
        var now = DateTime.UtcNow;
        return _period switch
        {
            "Today"      => (now.Date, now.Date.AddDays(1).AddTicks(-1)),
            "This Week"  => (now.Date.AddDays(-(int)now.DayOfWeek), now.Date.AddDays(7 - (int)now.DayOfWeek).AddTicks(-1)),
            "This Month" => (new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc), new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc).AddMonths(1).AddTicks(-1)),
            _            => (DateTime.MinValue, DateTime.MaxValue)
        };
    }

    private static string MethodIcon(PaymentMethod m) => m switch
    {
        PaymentMethod.GCash  => "bi-phone-fill",
        PaymentMethod.Bank   => "bi-bank",
        PaymentMethod.PayPal => "bi-paypal",
        _ => "bi-credit-card"
    };
}
