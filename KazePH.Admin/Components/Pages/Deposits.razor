@page "/admin/deposits"
@rendermode InteractiveServer
@inject ITopUpService TopUpService
@inject KazeDbContext Db
@inject IConfiguration Configuration

<PageTitle>Deposits – KazePH Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Cash-In Requests</h4>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

<!-- Filter Tabs -->
<ul class="nav nav-pills mb-4">
    @foreach (var tab in new[] { "Pending", "All", "Approved", "Rejected" })
    {
        <li class="nav-item me-1">
            <button class="nav-link @(_filter == tab ? "active" : "")" @onclick="() => SetFilter(tab)">
                @tab
                @if (tab == "Pending" && _pendingCount > 0)
                {
                    <span class="badge bg-danger ms-1">@_pendingCount</span>
                }
            </button>
        </li>
    }
</ul>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else if (_filtered.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>No @(_filter.ToLower()) requests.
    </div>
}
else
{
    <!-- Desktop table -->
    <div class="table-responsive d-none d-md-block">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th>Receipt</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _filtered)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold small">@(r.User?.Username ?? "—")</div>
                            <div class="text-muted" style="font-size:0.72rem">@r.UserId[..8]…</div>
                        </td>
                        <td class="fw-bold text-success">₱@r.Amount.ToString("N2")</td>
                        <td><span class="badge bg-secondary">@r.PaymentMethod</span></td>
                        <td class="text-muted small">@r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td><span class="badge @StatusBadge(r.Status)">@r.Status</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(r.ReceiptUrl))
                            {
                                <a href="@(_webBaseUrl + r.ReceiptUrl)" target="_blank" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-image me-1"></i>View
                                </a>
                            }
                            else { <span class="text-muted small">None</span> }
                        </td>
                        <td>
                            @if (r.Status == TopUpStatus.Pending)
                            {
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-success" title="Approve" @onclick="() => OpenApprove(r)">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" title="Reject" @onclick="() => OpenReject(r)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">@r.ReviewedAt?.ToLocalTime().ToString("MMM d")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile card list -->
    <div class="d-flex d-md-none flex-column gap-3">
        @foreach (var r in _filtered)
        {
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="fw-semibold">@(r.User?.Username ?? "—")</div>
                        <div class="text-muted small">@r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                    </div>
                    <span class="badge @StatusBadge(r.Status)">@r.Status</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="fw-bold text-success me-2">₱@r.Amount.ToString("N2")</span>
                        <span class="badge bg-secondary">@r.PaymentMethod</span>
                    </div>
                    <div class="d-flex gap-1">
                        @if (!string.IsNullOrEmpty(r.ReceiptUrl))
                        {
                            <a href="@(_webBaseUrl + r.ReceiptUrl)" target="_blank" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-image"></i>
                            </a>
                        }
                        @if (r.Status == TopUpStatus.Pending)
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => OpenApprove(r)"><i class="bi bi-check-lg"></i></button>
                            <button class="btn btn-sm btn-danger" @onclick="() => OpenReject(r)"><i class="bi bi-x-lg"></i></button>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(r.AdminNote))
                {
                    <div class="text-muted small fst-italic mt-2"><i class="bi bi-chat-left-text me-1"></i>@r.AdminNote</div>
                }
            </div>
        }
    </div>
}

<!-- Approve Modal -->
@if (_approveTarget is not null)
{
    <div class="modal-backdrop fade show" style="opacity:.6;z-index:1040"></div>
    <div class="modal d-block" tabindex="-1" style="z-index:1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title"><i class="bi bi-check-circle text-success me-2"></i>Approve Cash-In</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p>Credit <strong class="text-success">₱@_approveTarget.Amount.ToString("N2")</strong> to <strong>@(_approveTarget.User?.Username ?? _approveTarget.UserId[..8])</strong>'s wallet?</p>
                    <div class="mb-2">
                        <label class="form-label">Admin Note (optional)</label>
                        <input type="text" class="form-control" @bind="_adminNote" placeholder="e.g. Verified via GCash screenshot" />
                    </div>
                    @if (!string.IsNullOrEmpty(_actionError))
                    {
                        <div class="alert alert-danger py-2 small mt-2">@_actionError</div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-success" @onclick="ConfirmApprove" disabled="@_acting">
                        @if (_acting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                        Approve & Credit
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Reject Modal -->
@if (_rejectTarget is not null)
{
    <div class="modal-backdrop fade show" style="opacity:.6;z-index:1040"></div>
    <div class="modal d-block" tabindex="-1" style="z-index:1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title"><i class="bi bi-x-circle text-danger me-2"></i>Reject Cash-In</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p>Reject <strong class="text-danger">₱@_rejectTarget.Amount.ToString("N2")</strong> from <strong>@(_rejectTarget.User?.Username ?? _rejectTarget.UserId[..8])</strong>?</p>
                    <div class="mb-2">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_adminNote" placeholder="e.g. Receipt unclear, cannot verify" />
                    </div>
                    @if (!string.IsNullOrEmpty(_actionError))
                    {
                        <div class="alert alert-danger py-2 small mt-2">@_actionError</div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmReject" disabled="@_acting">
                        @if (_acting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                        Reject
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string _filter = "Pending";
    private string _webBaseUrl = string.Empty;
    private List<TopUpRequest> _allRequests = new();
    private int _pendingCount;

    private TopUpRequest? _approveTarget;
    private TopUpRequest? _rejectTarget;
    private string _adminNote = string.Empty;
    private string _actionError = string.Empty;
    private bool _acting;

    private List<TopUpRequest> _filtered => _filter == "All"
        ? _allRequests
        : _allRequests.Where(r => r.Status.ToString() == _filter).ToList();

    protected override async Task OnInitializedAsync()
    {
        _webBaseUrl = Configuration["WebApp:BaseUrl"] ?? "http://localhost:5246";
        await LoadAsync();
    }

    private void SetFilter(string f) => _filter = f;

    private async Task LoadAsync()
    {
        _loading = true;
        _allRequests = await Db.TopUpRequests
            .Include(r => r.User)
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();
        _pendingCount = _allRequests.Count(r => r.Status == TopUpStatus.Pending);
        _loading = false;
    }

    private void OpenApprove(TopUpRequest r)
    {
        _approveTarget = r; _rejectTarget = null;
        _adminNote = string.Empty; _actionError = string.Empty;
    }

    private void OpenReject(TopUpRequest r)
    {
        _rejectTarget = r; _approveTarget = null;
        _adminNote = string.Empty; _actionError = string.Empty;
    }

    private void CloseModals() { _approveTarget = null; _rejectTarget = null; }

    private async Task ConfirmApprove()
    {
        if (_approveTarget is null) return;
        _acting = true; _actionError = string.Empty;
        try
        {
            await TopUpService.ApproveTopUpAsync(_approveTarget.Id, _adminNote);
            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = ex.Message; }
        finally { _acting = false; }
    }

    private async Task ConfirmReject()
    {
        if (_rejectTarget is null) return;
        if (string.IsNullOrWhiteSpace(_adminNote)) { _actionError = "Please provide a reason for rejection."; return; }
        _acting = true; _actionError = string.Empty;
        try
        {
            await TopUpService.RejectTopUpAsync(_rejectTarget.Id, _adminNote);
            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex) { _actionError = ex.Message; }
        finally { _acting = false; }
    }

    private static string StatusBadge(TopUpStatus s) => s switch
    {
        TopUpStatus.Approved => "bg-success",
        TopUpStatus.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };
}
