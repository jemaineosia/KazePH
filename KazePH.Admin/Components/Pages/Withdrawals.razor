@page "/admin/withdrawals"
@rendermode InteractiveServer
@inject IWithdrawalService WithdrawalService
@inject KazeDbContext Db
@inject IConfiguration Configuration
@inject IWebHostEnvironment Env

@using System.Text.Json
@using KazePH.Core.Enums

<PageTitle>Withdrawals – KazePH Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Cash-Out Requests</h4>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

<!-- Filter Tabs -->
<ul class="nav nav-pills mb-4">
    @foreach (var tab in new[] { "Pending", "Processing", "All", "Completed", "Rejected" })
    {
        <li class="nav-item me-1">
            <button class="nav-link @(_filter == tab ? "active" : "")" @onclick="() => SetFilter(tab)">
                @tab
                @if (tab == "Pending" && _pendingCount > 0)
                {
                    <span class="badge bg-danger ms-1">@_pendingCount</span>
                }
            </button>
        </li>
    }
</ul>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else if (_filtered.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>No @(_filter.ToLower()) withdrawal requests.
    </div>
}
else
{
    <!-- Desktop table -->
    <div class="table-responsive d-none d-md-block">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Amount</th>
                    <th>Fee</th>
                    <th>Net</th>
                    <th>Method</th>
                    <th>Destination</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th>Receipt</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _filtered)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold small">@(r.User?.Username ?? "—")</div>
                            <div class="text-muted" style="font-size:0.72rem">@r.UserId[..8]…</div>
                        </td>
                        <td class="fw-bold">₱@r.Amount.ToString("N2")</td>
                        <td class="text-warning small">–₱@r.Fee.ToString("N2")</td>
                        <td class="fw-bold text-success">₱@r.NetAmount.ToString("N2")</td>
                        <td><span class="badge bg-secondary">@r.PaymentMethod</span></td>
                        <td><div class="small">@FormatDestination(r.DestinationDetails, r.PaymentMethod)</div></td>
                        <td class="text-muted small">@r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td><span class="badge @StatusBadge(r.Status)">@r.Status</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(r.ReceiptUrl))
                            {
                                <a href="@r.ReceiptUrl" target="_blank" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-image me-1"></i>View
                                </a>
                            }
                            else { <span class="text-muted small">None</span> }
                        </td>
                        <td>
                            @if (r.Status is WithdrawalStatus.Pending or WithdrawalStatus.Processing)
                            {
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-success" title="Approve" @onclick="() => OpenApprove(r)">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" title="Reject" @onclick="() => OpenReject(r)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">@r.ProcessedAt?.ToLocalTime().ToString("MMM d")</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile card list -->
    <div class="d-flex d-md-none flex-column gap-3">
        @foreach (var r in _filtered)
        {
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="fw-semibold">@(r.User?.Username ?? "—")</div>
                        <div class="text-muted small">@r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                    </div>
                    <span class="badge @StatusBadge(r.Status)">@r.Status</span>
                </div>
                <div class="mb-2 small">
                    <span class="fw-bold me-1">₱@r.Amount.ToString("N2")</span>
                    <span class="text-warning me-1">–₱@r.Fee.ToString("N2") fee</span>
                    <span class="text-success fw-bold">= ₱@r.NetAmount.ToString("N2")</span>
                </div>
                <div class="small text-muted mb-2">
                    <span class="badge bg-secondary me-1">@r.PaymentMethod</span>
                    @FormatDestination(r.DestinationDetails, r.PaymentMethod)
                </div>
                <div class="d-flex gap-1">
                    @if (!string.IsNullOrEmpty(r.ReceiptUrl))
                    {
                        <a href="@r.ReceiptUrl" target="_blank" class="btn btn-sm btn-outline-info">
                            <i class="bi bi-image"></i>
                        </a>
                    }
                    @if (r.Status is WithdrawalStatus.Pending or WithdrawalStatus.Processing)
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => OpenApprove(r)"><i class="bi bi-check-lg"></i></button>
                        <button class="btn btn-sm btn-danger" @onclick="() => OpenReject(r)"><i class="bi bi-x-lg"></i></button>
                    }
                </div>
                @if (!string.IsNullOrEmpty(r.AdminNote))
                {
                    <div class="text-muted small fst-italic mt-2"><i class="bi bi-chat-left-text me-1"></i>@r.AdminNote</div>
                }
            </div>
        }
    </div>
}

<!-- Approve Modal -->
@if (_approveTarget is not null)
{
    <div class="modal-backdrop fade show" style="opacity:.6;z-index:1040"></div>
    <div class="modal d-block" tabindex="-1" style="z-index:1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title"><i class="bi bi-check-circle text-success me-2"></i>Approve Withdrawal</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-1">
                        Send <strong class="text-success">₱@_approveTarget.NetAmount.ToString("N2")</strong> to
                        <strong>@(_approveTarget.User?.Username ?? _approveTarget.UserId[..8])</strong>
                    </p>
                    <p class="text-muted small mb-3">
                        via <strong>@_approveTarget.PaymentMethod</strong> —
                        @FormatDestination(_approveTarget.DestinationDetails, _approveTarget.PaymentMethod)
                    </p>

                    <div class="mb-3">
                        <label class="form-label">Upload Payment Receipt <span class="text-danger">*</span></label>
                        <InputFile class="form-control" OnChange="OnReceiptSelected" accept="image/*,application/pdf" />
                        @if (_receiptFile is not null)
                        {
                            <div class="text-muted small mt-1">
                                <i class="bi bi-paperclip me-1"></i>@_receiptFile.Name
                                (@(((double)_receiptFile.Size / 1024 / 1024).ToString("F2")) MB)
                            </div>
                        }
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Admin Note (optional)</label>
                        <input type="text" class="form-control" @bind="_adminNote"
                               placeholder="e.g. Sent via GCash 09XX XXX XXXX" />
                    </div>

                    @if (!string.IsNullOrEmpty(_actionError))
                    {
                        <div class="alert alert-danger py-2 small mt-2">@_actionError</div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-success" @onclick="ConfirmApprove" disabled="@(_acting || _receiptFile is null)">
                        @if (_acting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                        Approve & Mark Sent
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Reject Modal -->
@if (_rejectTarget is not null)
{
    <div class="modal-backdrop fade show" style="opacity:.6;z-index:1040"></div>
    <div class="modal d-block" tabindex="-1" style="z-index:1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title"><i class="bi bi-x-circle text-danger me-2"></i>Reject Withdrawal</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Reject <strong class="text-danger">₱@_rejectTarget.Amount.ToString("N2")</strong> from
                        <strong>@(_rejectTarget.User?.Username ?? _rejectTarget.UserId[..8])</strong>?
                        Funds will be returned to their wallet.
                    </p>
                    <div class="mb-2">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_adminNote"
                               placeholder="e.g. Incorrect account details provided" />
                    </div>
                    @if (!string.IsNullOrEmpty(_actionError))
                    {
                        <div class="alert alert-danger py-2 small mt-2">@_actionError</div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmReject" disabled="@_acting">
                        @if (_acting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                        Reject & Return Funds
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const long MaxReceiptSize = 10 * 1024 * 1024; // 10 MB

    private bool _loading = true;
    private string _filter = "Pending";
    private string _adminBaseUrl = string.Empty;
    private List<WithdrawalRequest> _allRequests = new();
    private int _pendingCount;

    private WithdrawalRequest? _approveTarget;
    private WithdrawalRequest? _rejectTarget;
    private IBrowserFile? _receiptFile;
    private string _adminNote = string.Empty;
    private string _actionError = string.Empty;
    private bool _acting;

    private List<WithdrawalRequest> _filtered => _filter switch
    {
        "Pending"    => _allRequests.Where(r => r.Status == WithdrawalStatus.Pending).ToList(),
        "Processing" => _allRequests.Where(r => r.Status == WithdrawalStatus.Processing).ToList(),
        "Completed"  => _allRequests.Where(r => r.Status == WithdrawalStatus.Completed).ToList(),
        "Rejected"   => _allRequests.Where(r => r.Status == WithdrawalStatus.Rejected).ToList(),
        _ => _allRequests
    };

    protected override async Task OnInitializedAsync()
    {
        _adminBaseUrl = Configuration["AdminApp:SelfBaseUrl"] ?? "http://localhost:5048";
        await LoadAsync();
    }

    private void SetFilter(string f) => _filter = f;

    private async Task LoadAsync()
    {
        _loading = true;
        _allRequests = await Db.WithdrawalRequests
            .Include(r => r.User)
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();
        _pendingCount = _allRequests.Count(r => r.Status == WithdrawalStatus.Pending);
        _loading = false;
    }

    private void OpenApprove(WithdrawalRequest r)
    {
        _approveTarget = r; _rejectTarget = null;
        _receiptFile = null; _adminNote = string.Empty; _actionError = string.Empty;
    }

    private void OpenReject(WithdrawalRequest r)
    {
        _rejectTarget = r; _approveTarget = null;
        _adminNote = string.Empty; _actionError = string.Empty;
    }

    private void CloseModals()
    {
        _approveTarget = null; _rejectTarget = null;
        _receiptFile = null; _adminNote = string.Empty; _actionError = string.Empty;
    }

    private void OnReceiptSelected(InputFileChangeEventArgs e) => _receiptFile = e.File;

    private async Task ConfirmApprove()
    {
        if (_approveTarget is null || _receiptFile is null) return;
        _acting = true; _actionError = string.Empty;
        try
        {
            // Save receipt to Admin's wwwroot/uploads/withdrawal-receipts/
            var uploadsDir = Path.Combine(Env.WebRootPath, "uploads", "withdrawal-receipts");
            Directory.CreateDirectory(uploadsDir);

            var ext = Path.GetExtension(_receiptFile.Name);
            var fileName = $"{Guid.NewGuid()}{ext}";
            var filePath = Path.Combine(uploadsDir, fileName);

            await using (var stream = _receiptFile.OpenReadStream(MaxReceiptSize))
            await using (var fs = File.Create(filePath))
            {
                await stream.CopyToAsync(fs);
            }

            // Store full URL so user can access it from the admin server
            var receiptUrl = $"{_adminBaseUrl}/uploads/withdrawal-receipts/{fileName}";

            // Transition: Pending → Processing → Completed
            if (_approveTarget.Status == WithdrawalStatus.Pending)
                await WithdrawalService.ProcessWithdrawalAsync(_approveTarget.Id);

            await WithdrawalService.CompleteWithdrawalAsync(_approveTarget.Id, receiptUrl);

            // Persist optional admin note (CompleteWithdrawalAsync doesn't accept one)
            if (!string.IsNullOrWhiteSpace(_adminNote))
            {
                var req = await Db.WithdrawalRequests.FindAsync(_approveTarget.Id);
                if (req is not null) { req.AdminNote = _adminNote; await Db.SaveChangesAsync(); }
            }

            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _acting = false;
        }
    }

    private async Task ConfirmReject()
    {
        if (_rejectTarget is null) return;
        if (string.IsNullOrWhiteSpace(_adminNote)) { _actionError = "Please provide a reason for rejection."; return; }
        _acting = true; _actionError = string.Empty;
        try
        {
            await WithdrawalService.RejectWithdrawalAsync(_rejectTarget.Id, _adminNote);
            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _acting = false;
        }
    }

    private static string StatusBadge(WithdrawalStatus s) => s switch
    {
        WithdrawalStatus.Completed  => "bg-success",
        WithdrawalStatus.Rejected   => "bg-danger",
        WithdrawalStatus.Processing => "bg-info text-dark",
        _ => "bg-warning text-dark"
    };

    private static string FormatDestination(string json, PaymentMethod method)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            var acctNum  = root.TryGetProperty("accountNumber", out var n)  ? n.GetString()  : null;
            var acctName = root.TryGetProperty("accountName",   out var an) ? an.GetString() : null;
            var bank     = root.TryGetProperty("bankName",      out var b)  ? b.GetString()  : null;
            return method == PaymentMethod.Bank
                ? $"{bank} · {acctNum} · {acctName}"
                : $"{acctNum} · {acctName}";
        }
        catch { return json; }
    }
}

