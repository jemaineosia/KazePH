@inherits LayoutComponentBase

<!-- ── Offcanvas Sidebar (mobile) ──────────────────────────────────────── -->
<div class="offcanvas offcanvas-start kaze-offcanvas" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header border-bottom border-secondary">
        <a class="offcanvas-title navbar-brand text-white fw-bold" href="/">
            <span class="text-danger">Kaze</span>PH
        </a>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0">
        <ul class="nav flex-column pt-2">
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/" Match="NavLinkMatch.All" @onclick="CloseOffcanvas">
                    <i class="bi bi-house-fill"></i> Home
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/events" @onclick="CloseOffcanvas">
                    <i class="bi bi-calendar-event-fill"></i> Events
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/wallet" @onclick="CloseOffcanvas">
                    <i class="bi bi-wallet2"></i> Wallet
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/friends" @onclick="CloseOffcanvas">
                    <i class="bi bi-people-fill"></i> Friends
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/chat" @onclick="CloseOffcanvas">
                    <i class="bi bi-chat-dots-fill"></i> Chat
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/rankings" @onclick="CloseOffcanvas">
                    <i class="bi bi-trophy-fill"></i> Rankings
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="kaze-sidebar-link" href="/profile" @onclick="CloseOffcanvas">
                    <i class="bi bi-person-circle"></i> Profile
                </NavLink>
            </li>
            <li class="nav-item mt-2 border-top border-secondary pt-2">
                <AuthorizeView>
                    <Authorized>
                        <form method="post" action="/logout">
                            <AntiforgeryToken />
                            <button type="submit" class="kaze-sidebar-link border-0 bg-transparent w-100 text-start">
                                <i class="bi bi-box-arrow-right"></i> Sign Out
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="kaze-sidebar-link">
                            <i class="bi bi-person-circle"></i> Sign In
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </li>
        </ul>
    </div>
</div>

<!-- ── Top Navbar ──────────────────────────────────────────────────────── -->
<nav class="navbar kaze-navbar fixed-top">
    <div class="container-fluid px-3">

        <!-- Hamburger (mobile only) -->
        <button class="navbar-toggler d-md-none border-0 text-white me-2"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#sidebarMenu"
                aria-controls="sidebarMenu">
            <i class="bi bi-list fs-4"></i>
        </button>

        <!-- Brand -->
        <a class="navbar-brand text-white fw-bold" href="/">
            <span class="text-danger">Kaze</span>PH
        </a>

        <!-- Desktop nav links (hidden on mobile) -->
        <div class="d-none d-md-flex align-items-center gap-1 flex-grow-1 ms-4">
            <NavLink class="kaze-nav-link" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-house-fill me-1"></i>Home
            </NavLink>
            <NavLink class="kaze-nav-link" href="/events">
                <i class="bi bi-calendar-event-fill me-1"></i>Events
            </NavLink>
            <NavLink class="kaze-nav-link" href="/wallet">
                <i class="bi bi-wallet2 me-1"></i>Wallet
            </NavLink>
            <NavLink class="kaze-nav-link" href="/friends">
                <i class="bi bi-people-fill me-1"></i>Friends
            </NavLink>
            <NavLink class="kaze-nav-link" href="/chat">
                <i class="bi bi-chat-dots-fill me-1"></i>Chat
            </NavLink>
            <NavLink class="kaze-nav-link" href="/rankings">
                <i class="bi bi-trophy-fill me-1"></i>Rankings
            </NavLink>
        </div>

        <!-- Right side: notification bell + auth links -->
        <div class="d-flex align-items-center gap-2 ms-auto">
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-link text-white p-1 position-relative" title="Notifications">
                        <i class="bi bi-bell fs-5"></i>
                    </button>
                    <NavLink class="d-none d-md-flex kaze-nav-link" href="/profile">
                        <i class="bi bi-person-circle fs-5"></i>
                    </NavLink>
                    <form method="post" action="/logout" class="d-none d-md-block">
                        <AntiforgeryToken />
                        <button type="submit" class="kaze-nav-link border-0 bg-transparent">
                            <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="kaze-nav-link d-none d-md-flex align-items-center">
                        <i class="bi bi-person-circle me-1"></i>Sign In
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

    </div>
</nav>

<!-- ── Page Content ─────────────────────────────────────────────────────── -->
<main class="kaze-main">
    <div class="container-fluid px-3 py-3">
        @Body
    </div>
</main>

<!-- ── Blazor Error UI ──────────────────────────────────────────────────── -->
<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private void CloseOffcanvas() { }
}
