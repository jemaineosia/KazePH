@page "/wallet"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IWalletService WalletService
@inject KazeDbContext Db
@inject AuthenticationStateProvider AuthState
@inject IConfiguration Config

@using KazePH.Core.Enums
@using System.Text.Json

<PageTitle>Wallet – KazePH</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else
{
    <!-- Balance Card -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0"><i class="bi bi-wallet2 me-2 text-danger"></i>My Wallet</h5>
                <div class="d-flex gap-2">
                    <a href="/wallet/topup" class="btn btn-primary btn-sm fw-semibold">
                        <i class="bi bi-plus-circle me-1"></i>Cash In
                    </a>
                    <a href="/wallet/cashout" class="btn btn-outline-danger btn-sm fw-semibold">
                        <i class="bi bi-arrow-up-circle me-1"></i>Cash Out
                    </a>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-6 col-md-4">
                    <div class="p-3 rounded" style="background:#0f0f1e">
                        <div class="text-muted small mb-1">Available</div>
                        <div class="fs-3 fw-bold text-success">₱@(_wallet?.AvailableBalance.ToString("N2") ?? "0.00")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 rounded" style="background:#0f0f1e">
                        <div class="text-muted small mb-1">Locked in Bets</div>
                        <div class="fs-3 fw-bold text-warning">₱@(_wallet?.LockedBalance.ToString("N2") ?? "0.00")</div>
                    </div>
                </div>
                @if ((_wallet?.PendingWithdrawalBalance ?? 0) > 0)
                {
                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded" style="background:#0f0f1e">
                            <div class="text-muted small mb-1">Pending Withdrawal</div>
                            <div class="fs-3 fw-bold text-secondary">₱@(_wallet!.PendingWithdrawalBalance.ToString("N2"))</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Betting Activity -->
    <h6 class="fw-semibold mb-3">Betting Activity</h6>
    @if (_txns.Count == 0)
    {
        <div class="text-center text-muted py-4 mb-4">
            <i class="bi bi-controller fs-2 d-block mb-2"></i>No bet activity yet.
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2 mb-4">
            @foreach (var t in _txns)
            {
                <div class="card p-3 border-0" style="background:#12122a">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:36px;height:36px;background:#1a1a2e;flex-shrink:0">
                                <i class="bi @TxnIcon(t.Type) @TxnColor(t.Type)"></i>
                            </div>
                            <div>
                                <div class="fw-semibold small">@t.Description</div>
                                <div class="text-muted" style="font-size:.75rem">
                                    @t.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </div>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold @TxnColor(t.Type)">
                                @TxnSign(t.Type)₱@t.Amount.ToString("N2")
                            </div>
                            <div class="text-muted" style="font-size:.72rem">@TxnLabel(t.Type)</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Cash-Out History -->
    <h6 class="fw-semibold mb-3">Cash-Out History</h6>
    @if (_withdrawals.Count == 0)
    {
        <div class="text-center text-muted py-4">
            <i class="bi bi-arrow-up-circle fs-2 d-block mb-2"></i>No cash-out requests yet.
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2 mb-4">
            @foreach (var w in _withdrawals)
            {
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">₱@w.Amount.ToString("N2") <span class="text-muted small fw-normal">→ receive <span class="text-success">₱@w.NetAmount.ToString("N2")</span></span></div>
                            <div class="text-muted small">@w.PaymentMethod &nbsp;·&nbsp; @DestinationSummary(w.DestinationDetails) &nbsp;·&nbsp; @w.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                            @if (!string.IsNullOrEmpty(w.AdminNote))
                            {
                                <div class="text-muted small fst-italic mt-1"><i class="bi bi-chat-left-text me-1"></i>@w.AdminNote</div>
                            }
                        </div>
                        <div class="text-end">
                            <span class="badge @WithdrawalBadge(w.Status)">@w.Status</span>
                            @if (!string.IsNullOrEmpty(w.ReceiptUrl))
                            {
                                <div class="mt-1">
                                    <a href="@w.ReceiptUrl" target="_blank" class="btn btn-sm btn-outline-info py-0 px-2" style="font-size:0.72rem">
                                        <i class="bi bi-image me-1"></i>Receipt
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Cash-In History -->
    <h6 class="fw-semibold mb-3">Cash-In History</h6>
    @if (_topUps.Count == 0)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
            No cash-in requests yet.<br />
            <a href="/wallet/topup" class="btn btn-primary btn-sm mt-3">Make your first Cash-In</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var t in _topUps)
            {
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">₱@t.Amount.ToString("N2")</div>
                            <div class="text-muted small">@t.PaymentMethod &nbsp;·&nbsp; @t.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                            @if (!string.IsNullOrEmpty(t.AdminNote))
                            {
                                <div class="text-muted small fst-italic mt-1"><i class="bi bi-chat-left-text me-1"></i>@t.AdminNote</div>
                            }
                        </div>
                        <span class="badge @CashInBadge(t.Status)">@t.Status</span>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private bool _loading = true;
    private KazePH.Core.Models.Wallet? _wallet;
    private List<TopUpRequest> _topUps = new();
    private List<WithdrawalRequest> _withdrawals = new();
    private List<WalletTransaction> _txns = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _wallet = await WalletService.GetBalanceAsync(userId);

        _topUps = await Db.TopUpRequests
            .Where(r => r.UserId == userId)
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();

        _withdrawals = await Db.WithdrawalRequests
            .Where(r => r.UserId == userId)
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();

        _txns = await Db.WalletTransactions
            .Where(t => t.UserId == userId)
            .OrderByDescending(t => t.CreatedAt)
            .ToListAsync();

        _loading = false;
    }

    private static string CashInBadge(TopUpStatus status) => status switch
    {
        TopUpStatus.Approved => "bg-success",
        TopUpStatus.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };

    private static string WithdrawalBadge(WithdrawalStatus status) => status switch
    {
        WithdrawalStatus.Completed  => "bg-success",
        WithdrawalStatus.Rejected   => "bg-danger",
        WithdrawalStatus.Processing => "bg-info text-dark",
        _ => "bg-warning text-dark"
    };

    private static string DestinationSummary(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("accountNumber", out var num))
                return num.GetString() ?? "—";
        }
        catch { }
        return "—";
    }

    private static string TxnIcon(WalletTransactionType type) => type switch
    {
        WalletTransactionType.WinningsReceived => "bi-trophy-fill",
        WalletTransactionType.StakeForfeited   => "bi-x-circle-fill",
        WalletTransactionType.DrawRefund       => "bi-arrow-counterclockwise",
        WalletTransactionType.StakeLocked      => "bi-lock-fill",
        WalletTransactionType.StakeReleased    => "bi-unlock-fill",
        WalletTransactionType.TopUp            => "bi-plus-circle-fill",
        WalletTransactionType.Withdrawal       => "bi-arrow-up-circle-fill",
        _                                      => "bi-circle"
    };

    private static string TxnColor(WalletTransactionType type) => type switch
    {
        WalletTransactionType.WinningsReceived => "text-success",
        WalletTransactionType.StakeForfeited   => "text-danger",
        WalletTransactionType.DrawRefund       => "text-secondary",
        WalletTransactionType.StakeLocked      => "text-warning",
        WalletTransactionType.StakeReleased    => "text-info",
        WalletTransactionType.TopUp            => "text-success",
        WalletTransactionType.Withdrawal       => "text-danger",
        _                                      => "text-muted"
    };

    private static string TxnSign(WalletTransactionType type) => type switch
    {
        WalletTransactionType.WinningsReceived => "+",
        WalletTransactionType.DrawRefund       => "+",
        WalletTransactionType.StakeReleased    => "+",
        WalletTransactionType.TopUp            => "+",
        WalletTransactionType.StakeForfeited   => "-",
        WalletTransactionType.Withdrawal       => "-",
        _                                      => ""
    };

    private static string TxnLabel(WalletTransactionType type) => type switch
    {
        WalletTransactionType.WinningsReceived => "Winnings",
        WalletTransactionType.StakeForfeited   => "Lost",
        WalletTransactionType.DrawRefund       => "Draw Refund",
        WalletTransactionType.StakeLocked      => "Staked",
        WalletTransactionType.StakeReleased    => "Released",
        WalletTransactionType.TopUp            => "Cash In",
        WalletTransactionType.Withdrawal       => "Cash Out",
        _                                      => ""
    };
}
