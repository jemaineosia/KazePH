@page "/login"
@layout AuthLayout

@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Nav

<PageTitle>Login – KazePH</PageTitle>

<h5 class="text-white fw-semibold text-center mb-4">Sign in to your account</h5>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger py-2 small" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>@_error
    </div>
}

<EditForm method="post" Model="Input" OnValidSubmit="HandleLogin" FormName="login">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText @bind-Value="Input!.Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
        <ValidationMessage For="() => Input!.Email" class="validation-message" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText @bind-Value="Input!.Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
        <ValidationMessage For="() => Input!.Password" class="validation-message" />
    </div>

    <div class="mb-4 form-check">
        <InputCheckbox @bind-Value="Input!.RememberMe" class="form-check-input" id="rememberMe" />
        <label class="form-check-label text-muted small" for="rememberMe">Remember me</label>
    </div>

    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
        Sign In
    </button>
</EditForm>

<hr class="border-secondary my-4" />

<p class="text-center text-muted small mb-0">
    Don't have an account? <a href="/register" class="fw-semibold">Create one</a>
</p>

@code {
    [SupplyParameterFromForm]
    public LoginInputModel? Input { get; set; }

    private string? _error;

    protected override void OnInitialized() => Input ??= new();

    private async Task HandleLogin()
    {
        if (Input is null) return;

        var result = await SignInManager.PasswordSignInAsync(
            Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);

        if (result.Succeeded)
            Nav.NavigateTo("/", forceLoad: true);
        else if (result.IsLockedOut)
            _error = "This account has been locked. Please try again later.";
        else
            _error = "Invalid email or password.";
    }

    public sealed class LoginInputModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
