@page "/events/{EventId:guid}"
@rendermode InteractiveServer
@inject IEventService EventService
@inject IWalletService WalletService
@inject IDisputeService DisputeService
@inject KazeDbContext Db
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_event?.Title ?? "Event") – KazePH</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else if (_event is null)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-exclamation-circle fs-1 d-block mb-3"></i>
        <div class="fw-semibold">Event not found</div>
        <a href="/events" class="btn btn-outline-secondary btn-sm mt-3">Back to Events</a>
    </div>
}
else
{
    <!-- Back link -->
    <div class="mb-3">
        <a href="/events" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to Events
        </a>
    </div>

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-3 gap-2">
        <div>
            <div class="d-flex gap-2 mb-2">
                <span class="badge @(_event.EventType == EventType.OneVsOne ? "bg-primary" : "")"
                      style="@(_event.EventType == EventType.Pool ? "background:#6f42c1" : "")">
                    @(_event.EventType == EventType.OneVsOne ? "1v1 Duel" : "Pool Bet")
                </span>
                <span class="badge @StatusBadge(_event.Status)">@_event.Status</span>
            </div>
            <h4 class="fw-bold mb-1">@_event.Title</h4>
            <div class="text-muted small">
                Created by <strong class="text-white">@(_event.Creator?.Username ?? "Unknown")</strong>
                &nbsp;·&nbsp;
                <i class="bi bi-calendar3 me-1"></i>@_event.EventDate.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_event.Description))
    {
        <div class="card border-0 mb-4" style="background:#12122a">
            <div class="card-body p-3">
                <div class="text-muted small" style="white-space:pre-wrap">@_event.Description</div>
            </div>
        </div>
    }

    <!-- Sides -->
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="card border-0 text-center" style="background:#12122a;border-left:3px solid #28a745 !important">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Side A</div>
                    <div class="fw-bold fs-5 text-success">@_event.SideA</div>
                    <div class="text-muted small mt-1">@SideCount("A") bet(s)</div>
                    <div class="text-success small fw-semibold mt-1">₱@SideTotal("A").ToString("N2") staked</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 text-center" style="background:#12122a;border-left:3px solid #dc3545 !important">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Side B</div>
                    <div class="fw-bold fs-5 text-danger">@_event.SideB</div>
                    <div class="text-muted small mt-1">@SideCount("B") bet(s)</div>
                    <div class="text-danger small fw-semibold mt-1">₱@SideTotal("B").ToString("N2") staked</div>
                </div>
            </div>
        </div>
    </div>

    @if (_event.StakeAmount.HasValue)
    {
        <div class="alert alert-warning py-2 mb-4">
            <i class="bi bi-lock-fill me-1"></i>
            @if (_event.EventType == EventType.OneVsOne)
            { <span>Fixed stake: <strong>₱@_event.StakeAmount.Value.ToString("N2")</strong> per player</span> }
            else
            { <span>Minimum bet: <strong>₱@_event.StakeAmount.Value.ToString("N2")</strong></span> }
        </div>
    }

    <!-- Total pool -->
    <div class="card border-0 mb-4 text-center" style="background:#1a1a2e">
        <div class="card-body py-3">
            <div class="text-muted small mb-1">Total Prize Pool</div>
            <div class="fs-3 fw-bold text-warning">₱@_event.BetEntries.Sum(b => b.Amount).ToString("N2")</div>
            <div class="text-muted small">@_event.BetEntries.Count total entries</div>
        </div>
    </div>

    @if (_event.EventType == EventType.OneVsOne && _event.Status == EventStatus.Open)
    {
        @if (_event.CreatorId == _userId)
        {
            <!-- ── Creator sees share panel ──────────────────────────────────── -->
            <div class="card border-0 mb-4" style="background:#12122a;border:1px solid #2a2a4a !important">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-1">
                        <i class="bi bi-share-fill text-success me-2"></i>Challenge is Live!
                    </h6>
                    <p class="text-muted small mb-3">
                        Your stake of <strong class="text-white">₱@_event.CreatorStake?.ToString("N2")</strong>
                        is locked. Share this link so your opponent can accept.
                    </p>

                    @if (_event.ChallengedUsername is not null)
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <i class="bi bi-person-fill me-1"></i>
                            Direct challenge sent to <strong>@_event.ChallengedUsername</strong>
                        </div>
                    }

                    <!-- Share URL box -->
                    <div class="input-group mb-2">
                        <input class="form-control kaze-input small" readonly value="@_shareUrl" />
                        <button class="btn btn-outline-success" @onclick="CopyShareUrl" title="Copy link">
                            @if (_copied)
                            { <i class="bi bi-check2 me-1"></i> }
                            else
                            { <i class="bi bi-clipboard me-1"></i> }
                            @(_copied ? "Copied!" : "Copy")
                        </button>
                    </div>
                    <div class="form-text">Anyone with this link can accept your challenge.</div>
                </div>
            </div>
        }
        else
        {
            <!-- ── Opponent sees accept panel ────────────────────────────────── -->
            @if (_alreadyJoined)
            {
                <div class="alert alert-success mb-4">
                    <i class="bi bi-check-circle-fill me-1"></i>
                    You have already joined this event.
                </div>
            }
            else if (_event.ChallengedUserId is not null && _event.ChallengedUserId != _userId)
            {
                <div class="alert alert-warning mb-4">
                    <i class="bi bi-lock-fill me-1"></i>
                    This challenge was sent to a specific user and cannot be accepted by you.
                </div>
            }
            else
            {
                <div class="card border-0 mb-4" style="background:#12122a;border:1px solid #e94560 !important">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-1">
                            <i class="bi bi-lightning-fill text-danger me-2"></i>Accept This Challenge
                        </h6>

                        @{
                            var opponentSideLabel = _event.CreatorSide == "A" ? _event.SideB : _event.SideA;
                            var opponentSideColor = _event.CreatorSide == "A" ? "text-danger" : "text-success";
                        }
                        <p class="text-muted small mb-3">
                            You will be betting on
                            <span class="fw-bold @opponentSideColor">@opponentSideLabel</span>
                            and must stake <strong class="text-white">₱@_event.OpponentStake?.ToString("N2")</strong>.
                        </p>

                        @if (_availableBalance.HasValue)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3 p-2 rounded" style="background:#0f0f1e">
                                <span class="text-muted small">Your available balance</span>
                                <span class="fw-bold @(_availableBalance >= _event.OpponentStake ? "text-success" : "text-danger")">
                                    ₱@_availableBalance.Value.ToString("N2")
                                </span>
                            </div>
                        }

                        <!-- Prize breakdown -->
                        <div class="row g-2 mb-3 text-center">
                            <div class="col-4">
                                <div class="p-2 rounded" style="background:#0f0f1e">
                                    <div class="text-muted" style="font-size:.7rem">You Risk</div>
                                    <div class="fw-bold text-danger">₱@_event.OpponentStake?.ToString("N2")</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2 rounded" style="background:#0f0f1e">
                                    <div class="text-muted" style="font-size:.7rem">Prize Pool</div>
                                    <div class="fw-bold text-warning">₱@((_event.CreatorStake + _event.OpponentStake)?.ToString("N2"))</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2 rounded" style="background:#0f0f1e">
                                    <div class="text-muted" style="font-size:.7rem">You Win</div>
                                    <div class="fw-bold text-success">₱@_event.CreatorStake?.ToString("N2")</div>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(_acceptError))
                        {
                            <div class="alert alert-danger py-2 mb-3">@_acceptError</div>
                        }

                        <AuthorizeView>
                            <Authorized>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-danger flex-fill fw-bold py-2"
                                            @onclick="AcceptAsync"
                                            disabled="@(_accepting || _rejecting || (_availableBalance.HasValue && _availableBalance < _event.OpponentStake))">
                                        @if (_accepting)
                                        { <span class="spinner-border spinner-border-sm me-2" role="status"></span> }
                                        <i class="bi bi-check-lg me-1"></i>Accept — Lock ₱@_event.OpponentStake?.ToString("N2")
                                    </button>
                                    <button class="btn btn-outline-secondary fw-bold py-2 px-3"
                                            @onclick="RejectAsync"
                                            disabled="@(_accepting || _rejecting)">
                                        @if (_rejecting)
                                        { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                        else
                                        { <i class="bi bi-x-lg me-1"></i> }
                                        Decline
                                    </button>
                                </div>
                                @if (_availableBalance.HasValue && _availableBalance < _event.OpponentStake)
                                {
                                    <div class="text-danger small text-center mt-1">Insufficient balance. <a href="/wallet/cashin">Top up</a></div>
                                }
                                @if (!string.IsNullOrEmpty(_rejectError))
                                {
                                    <div class="alert alert-danger py-2 mt-2 mb-0">@_rejectError</div>
                                }
                            </Authorized>
                            <NotAuthorized>
                                <a href="/login" class="btn btn-outline-light w-100">Sign in to accept</a>
                            </NotAuthorized>
                        </AuthorizeView>
                    </div>
                </div>
            }
        }
    }
    else if (_event.EventType == EventType.Pool && _event.Status == EventStatus.Open)
    {
        <div class="card border-0 mb-4" style="background:#12122a;border:1px solid #2a2a4a !important">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-danger me-1"></i>Place Your Bet</h6>
                <div class="text-center text-muted py-2">
                    <div class="small">Pool betting coming soon.</div>
                </div>
            </div>
        </div>
    }

    @* ── Completed: result banner ───────────────────────────────────────── *@
    @if (_event.Status == EventStatus.Completed && _event.Result is not null)
    {
        @if (_event.Result.DeclaredWinningSide == "Draw")
        {
            <div class="card border-0 mb-4 text-center" style="background:#12122a;border:2px solid #6c757d !important">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Result Declared</div>
                    <div class="fs-2 fw-bold text-secondary mb-1">
                        <i class="bi bi-handshake me-2"></i>It's a Draw!
                    </div>
                    <div class="text-muted small mb-1">All stakes have been returned to both players.</div>
                    <div class="text-muted small">
                        <i class="bi bi-calendar3 me-1"></i>@_event.Result.DeclaredAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 mb-4 text-center" style="background:#12122a;border:2px solid @(_event.Result.DeclaredWinningSide == "A" ? "#28a745" : "#dc3545") !important">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Result Declared</div>
                    <div class="fs-2 fw-bold @(_event.Result.DeclaredWinningSide == "A" ? "text-success" : "text-danger") mb-1">
                        <i class="bi bi-trophy-fill me-2"></i>@(_event.Result.DeclaredWinningSide == "A" ? _event.SideA : _event.SideB) Wins!
                    </div>
                    <div class="text-muted small">
                        <i class="bi bi-calendar3 me-1"></i>@_event.Result.DeclaredAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                    </div>
                </div>
            </div>
        }
    }

    @* ── Disputed: conflict banner + evidence form ────────────────────── *@
    @if (_event.Status == EventStatus.Disputed)
    {
        <div class="card border-0 mb-3" style="background:#12122a;border:2px solid #dc3545 !important">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-shield-exclamation text-danger fs-4"></i>
                    <h6 class="fw-bold mb-0 text-danger">Result Disputed</h6>
                </div>
                <p class="text-muted small mb-0">
                    Both players submitted different results. A dispute has been opened — both must submit evidence below.
                    An admin will review and declare the final result. The player found to have submitted a false result
                    will receive a <strong class="text-danger">reputation deduction</strong> once the ranking system launches.
                </p>
            </div>
        </div>

        @if (_event.BetEntries.Any(b => b.UserId == _userId))
        {
            @if (_myEvidenceSubmitted)
            {
                <div class="alert alert-success mb-4">
                    <i class="bi bi-check-circle-fill me-1"></i>
                    Your evidence has been submitted. Waiting for admin review.
                </div>
            }
            else
            {
                <div class="card border-0 mb-4" style="background:#12122a">
                    <div class="card-body p-4">
                        <h6 class="fw-semibold mb-3"><i class="bi bi-camera me-2"></i>Submit Your Proof</h6>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Screenshot / Photo URL <span class="text-danger">*</span></label>
                            <input class="form-control kaze-input" placeholder="https://imgur.com/..." @bind="_evidenceUrl" />
                            <div class="form-text">Upload a screenshot to Imgur, Google Drive, etc. and paste the link here.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Description <span class="text-muted fw-normal">(optional)</span></label>
                            <textarea class="form-control kaze-input" rows="2"
                                      placeholder="Explain why you won..."
                                      @bind="_evidenceDescription"></textarea>
                        </div>
                        @if (!string.IsNullOrEmpty(_evidenceError))
                        {
                            <div class="alert alert-danger py-2 mb-2">@_evidenceError</div>
                        }
                        <button class="btn btn-danger w-100" @onclick="SubmitEvidenceAsync" disabled="@_submittingEvidence">
                            @if (_submittingEvidence) { <span class="spinner-border spinner-border-sm me-2" role="status"></span> }
                            <i class="bi bi-upload me-1"></i>Submit Evidence
                        </button>
                    </div>
                </div>
            }
        }
    }

    @* ── Active 1v1: dual declaration panel ──────────────────────────── *@
    @if (_event.EventType == EventType.OneVsOne && _event.Status == EventStatus.Active)
    {
        @if (_event.BetEntries.Any(b => b.UserId == _userId))
        {
            var _myDecl = _event.ResultDeclarations.FirstOrDefault(d => d.DeclaringUserId == _userId);
            var _oppEntry = _event.BetEntries.FirstOrDefault(b => b.UserId != _userId);
            var _oppDecl = _oppEntry != null
                ? _event.ResultDeclarations.FirstOrDefault(d => d.DeclaringUserId == _oppEntry.UserId)
                : null;
            @if (_myDecl == null)
            {
                <div class="card border-0 mb-4" style="background:#12122a;border:1px solid #e94560 !important">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-2"><i class="bi bi-flag-fill text-danger me-2"></i>What was the result?</h6>
                        <p class="text-muted small mb-4">
                            Both players must pick the same result for the event to settle automatically.
                            If your choices differ, a <strong class="text-warning">dispute</strong> will be opened.
                        </p>

                        <!-- 3 outcome buttons -->
                        <div class="d-flex flex-column gap-2 mb-4">
                            <button class="btn w-100 text-start fw-semibold py-3 px-4"
                                    style="background:@(_newDeclareSide == "A" ? "rgba(40,167,69,.25)" : "#0f0f1e");border:2px solid @(_newDeclareSide == "A" ? "#28a745" : "#2a2a4a")"
                                    @onclick='() => _newDeclareSide = "A"'>
                                <i class="bi bi-trophy-fill me-2 text-success"></i>
                                <span class="text-success">@_event.SideA Won</span>
                                @if (_newDeclareSide == "A") { <i class="bi bi-check-circle-fill text-success float-end mt-1"></i> }
                            </button>
                            <button class="btn w-100 text-start fw-semibold py-3 px-4"
                                    style="background:@(_newDeclareSide == "B" ? "rgba(220,53,69,.25)" : "#0f0f1e");border:2px solid @(_newDeclareSide == "B" ? "#dc3545" : "#2a2a4a")"
                                    @onclick='() => _newDeclareSide = "B"'>
                                <i class="bi bi-trophy-fill me-2 text-danger"></i>
                                <span class="text-danger">@_event.SideB Won</span>
                                @if (_newDeclareSide == "B") { <i class="bi bi-check-circle-fill text-danger float-end mt-1"></i> }
                            </button>
                            <button class="btn w-100 text-start fw-semibold py-3 px-4"
                                    style="background:@(_newDeclareSide == "Draw" ? "rgba(108,117,125,.25)" : "#0f0f1e");border:2px solid @(_newDeclareSide == "Draw" ? "#6c757d" : "#2a2a4a")"
                                    @onclick='() => _newDeclareSide = "Draw"'>
                                <i class="bi bi-handshake-fill me-2 text-secondary"></i>
                                <span class="text-secondary">It's a Draw</span>
                                @if (_newDeclareSide == "Draw") { <i class="bi bi-check-circle-fill text-secondary float-end mt-1"></i> }
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(_declareNewError))
                        {
                            <div class="alert alert-danger py-2 mb-3">@_declareNewError</div>
                        }

                        @if (!string.IsNullOrEmpty(_newDeclareSide))
                        {
                            <!-- Dispute warning notice -->
                            <div class="alert mb-3 py-2" style="background:rgba(220,53,69,.1);border:1px solid rgba(220,53,69,.4)">
                                <div class="d-flex gap-2">
                                    <i class="bi bi-exclamation-triangle-fill text-warning mt-1 flex-shrink-0"></i>
                                    <div class="small text-muted">
                                        <strong class="text-warning">Heads up:</strong> If your opponent picks a different result,
                                        this becomes a <strong>dispute</strong>. You'll both need to submit proof (screenshots, etc.).
                                        Losing a dispute will result in a <strong class="text-danger">reputation deduction</strong> once the ranking system launches.
                                    </div>
                                </div>
                            </div>

                            <button class="btn btn-danger w-100 fw-bold py-2" @onclick="SubmitDeclarationAsync" disabled="@_declaringNew">
                                @if (_declaringNew) { <span class="spinner-border spinner-border-sm me-2" role="status"></span> }
                                <i class="bi bi-send-fill me-1"></i>
                                @if (_newDeclareSide == "Draw")
                                { <span>Declare It's a Draw</span> }
                                else
                                { <span>Declare <strong>@(_newDeclareSide == "A" ? _event.SideA : _event.SideB)</strong> Won</span> }
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 mb-4" style="background:#12122a">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-hourglass-split text-warning fs-3 mb-2 d-block"></i>
                        <div class="fw-semibold mb-1">Your declaration is in</div>
                        <div class="text-muted small mb-2">
                            You declared:
                            @if (_myDecl.DeclaredWinningSide == "Draw")
                            {
                                <strong class="text-secondary">It's a Draw</strong>
                            }
                            else
                            {
                                <strong class="@(_myDecl.DeclaredWinningSide == "A" ? "text-success" : "text-danger")">
                                    @(_myDecl.DeclaredWinningSide == "A" ? _event.SideA : _event.SideB) Won
                                </strong>
                            }
                        </div>
                        @if (_oppDecl == null)
                        {
                            <div class="text-muted small">Waiting for @(_oppEntry?.User?.Username ?? "your opponent") to declare...</div>
                        }
                    </div>
                </div>
            }
        }
    }

    <!-- ── Entries list ─────────────────────────────────────────────────── -->
    @if (_event.BetEntries.Any())
    {
        <h6 class="fw-semibold mb-3">Current Entries</h6>
        <div class="card border-0" style="background:#12122a">
            <div class="table-responsive">
                <table class="table table-dark table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted small">
                            <th>Player</th>
                            <th>Side</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _event.BetEntries.OrderByDescending(b => b.CreatedAt))
                        {
                            <tr>
                                <td class="small">
                                    @(entry.User?.Username ?? entry.UserId[..8])
                                    @if (entry.UserId == _event.CreatorId)
                                    { <span class="badge bg-secondary ms-1" style="font-size:.6rem">creator</span> }
                                </td>
                                <td>
                                    <span class="badge @(entry.Side == "A" ? "bg-success" : "bg-danger") bg-opacity-75">
                                        @(entry.Side == "A" ? _event.SideA : _event.SideB)
                                    </span>
                                </td>
                                <td class="fw-semibold text-white">₱@entry.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid EventId { get; set; }

    private Event? _event;
    private bool _loading = true;
    private string _userId = string.Empty;
    private decimal? _availableBalance;
    private bool _alreadyJoined;
    private bool _accepting;
    private string _acceptError = string.Empty;
    private bool _copied;
    private string _shareUrl = string.Empty;

    // Declaration flow
    private string _newDeclareSide = string.Empty;
    private bool _declaringNew;
    private string _declareNewError = string.Empty;

    // Reject challenge
    private bool _rejecting;
    private string _rejectError = string.Empty;

    // Dispute evidence
    private Guid _disputeId;
    private string _evidenceUrl = string.Empty;
    private string _evidenceDescription = string.Empty;
    private bool _submittingEvidence;
    private string _evidenceError = string.Empty;
    private bool _myEvidenceSubmitted;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        _event = await EventService.GetEventAsync(EventId);
        _loading = false;

        if (_event is null) return;

        _shareUrl = Nav.ToAbsoluteUri($"/events/{EventId}").ToString();

        _alreadyJoined = _event.BetEntries.Any(b => b.UserId == _userId);

        if (_event.Status == EventStatus.Disputed)
        {
            var dispute = await Db.Disputes
                .FirstOrDefaultAsync(d => d.EventId == _event.Id);
            if (dispute != null)
            {
                _disputeId = dispute.Id;
                _myEvidenceSubmitted = await Db.DisputeEvidence
                    .AnyAsync(e => e.DisputeId == dispute.Id && e.SubmittedByUserId == _userId);
            }
        }

        if (!string.IsNullOrEmpty(_userId) && _event.CreatorId != _userId)
        {
            var wallet = await WalletService.GetBalanceAsync(_userId);
            _availableBalance = wallet?.AvailableBalance;
        }
    }

    private async Task AcceptAsync()
    {
        _accepting = true;
        _acceptError = string.Empty;
        try
        {
            await EventService.AcceptChallengeAsync(EventId, _userId);
            _event = await EventService.GetEventAsync(EventId);
            _alreadyJoined = true;
        }
        catch (Exception ex)
        {
            _acceptError = ex.Message;
        }
        finally
        {
            _accepting = false;
        }
    }

    private async Task RejectAsync()
    {
        _rejecting = true;
        _rejectError = string.Empty;
        try
        {
            await EventService.RejectChallengeAsync(EventId, _userId);
            Nav.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            _rejectError = ex.Message;
        }
        finally
        {
            _rejecting = false;
        }
    }

    private async Task CopyShareUrl()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _shareUrl);
        _copied = true;
        await Task.Delay(2000);
        _copied = false;
    }

    private async Task SubmitDeclarationAsync()
    {
        _declaringNew = true;
        _declareNewError = string.Empty;
        try
        {
            await EventService.SubmitDeclarationAsync(EventId, _userId, _newDeclareSide);
            _event = await EventService.GetEventAsync(EventId);
            // Re-check dispute
            if (_event?.Status == EventStatus.Disputed)
            {
                var dispute = await Db.Disputes.FirstOrDefaultAsync(d => d.EventId == EventId);
                if (dispute != null) _disputeId = dispute.Id;
            }
        }
        catch (Exception ex)
        {
            _declareNewError = ex.Message;
        }
        finally
        {
            _declaringNew = false;
        }
    }

    private async Task SubmitEvidenceAsync()
    {
        if (string.IsNullOrWhiteSpace(_evidenceUrl))
        {
            _evidenceError = "Please provide a URL to your screenshot or proof.";
            return;
        }
        _submittingEvidence = true;
        _evidenceError = string.Empty;
        try
        {
            await DisputeService.SubmitEvidenceAsync(
                _disputeId,
                _userId,
                _evidenceUrl.Trim(),
                string.IsNullOrWhiteSpace(_evidenceDescription) ? null : _evidenceDescription.Trim());
            _myEvidenceSubmitted = true;
        }
        catch (Exception ex)
        {
            _evidenceError = ex.Message;
        }
        finally
        {
            _submittingEvidence = false;
        }
    }

    private int SideCount(string side) =>
        _event?.BetEntries.Count(b => b.Side.Equals(side, StringComparison.OrdinalIgnoreCase)) ?? 0;

    private decimal SideTotal(string side) =>
        _event?.BetEntries.Where(b => b.Side.Equals(side, StringComparison.OrdinalIgnoreCase)).Sum(b => b.Amount) ?? 0;

    private static string StatusBadge(EventStatus s) => s switch
    {
        EventStatus.Open      => "bg-success",
        EventStatus.Active    => "bg-info text-dark",
        EventStatus.Completed => "bg-secondary",
        EventStatus.Cancelled => "bg-warning text-dark",
        EventStatus.Disputed  => "bg-danger",
        _                     => "bg-secondary"
    };
}

