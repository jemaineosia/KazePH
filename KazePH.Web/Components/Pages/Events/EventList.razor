@page "/events"
@rendermode InteractiveServer
@inject IEventService EventService
@inject AuthenticationStateProvider AuthState

<PageTitle>Events – KazePH</PageTitle>

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Bet Events</h4>
        <p class="text-muted small mb-0">Browse open events and place your bets</p>
    </div>
    <AuthorizeView>
        <Authorized>
            <a href="/events/create" class="btn btn-danger btn-sm fw-semibold">
                <i class="bi bi-plus-lg me-1"></i>Create Event
            </a>
        </Authorized>
    </AuthorizeView>
</div>

<!-- Filter Pills -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    @foreach (var f in _filters)
    {
        <button class="btn btn-sm @(_filter == f ? "btn-danger" : "btn-outline-secondary")"
                @onclick="() => SetFilter(f)">@f</button>
    }
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else if (_events.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
        <div class="fw-semibold">No events found</div>
        <div class="small mt-1">
            @if (_filter == "My Events")
            { <span>You haven't created any events yet.</span> }
            else
            { <span>Be the first to create one!</span> }
        </div>
        <a href="/events/create" class="btn btn-danger btn-sm mt-3 fw-semibold">
            <i class="bi bi-plus-lg me-1"></i>Create Event
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var ev in _events)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a href="/events/@ev.Id" class="text-decoration-none">
                    <div class="card h-100 border-0 kaze-event-card" style="background:#12122a;transition:transform .15s">
                        <div class="card-body p-3">
                            <!-- Type badge + status -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge @(ev.EventType == EventType.OneVsOne ? "bg-primary" : "bg-purple")"
                                      style="@(ev.EventType == EventType.Pool ? "background:#6f42c1 !important" : "")">
                                    @(ev.EventType == EventType.OneVsOne ? "1v1 Duel" : "Pool Bet")
                                </span>
                                <span class="badge @StatusBadge(ev.Status)">@ev.Status</span>
                            </div>

                            <!-- Title -->
                            <div class="fw-bold text-white mb-1" style="font-size:0.95rem;line-height:1.3">
                                @ev.Title
                            </div>

                            <!-- Description preview -->
                            @if (!string.IsNullOrWhiteSpace(ev.Description))
                            {
                                <div class="text-muted small mb-2" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">
                                    @ev.Description
                                </div>
                            }

                            <!-- Sides -->
                            <div class="d-flex gap-2 mb-3">
                                <span class="badge bg-success bg-opacity-75 fw-normal">@ev.SideA</span>
                                <span class="text-muted small align-self-center">vs</span>
                                <span class="badge bg-danger bg-opacity-75 fw-normal">@ev.SideB</span>
                            </div>

                            <!-- Footer info -->
                            <div class="d-flex justify-content-between align-items-center pt-2 border-top border-secondary">
                                <div class="text-muted" style="font-size:0.72rem">
                                    <i class="bi bi-person-fill me-1"></i>@(ev.Creator?.Username ?? "Unknown")
                                </div>
                                <div class="text-muted" style="font-size:0.72rem">
                                    <i class="bi bi-people me-1"></i>@ev.BetEntries.Count entries
                                </div>
                            </div>
                            <div class="text-muted mt-1" style="font-size:0.72rem">
                                <i class="bi bi-calendar3 me-1"></i>
                                @ev.EventDate.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                            </div>
                            @if (ev.StakeAmount.HasValue)
                            {
                                <div class="text-warning mt-1" style="font-size:0.72rem">
                                    <i class="bi bi-lock-fill me-1"></i>Stake: ₱@ev.StakeAmount.Value.ToString("N2")
                                </div>
                            }
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

<style>
    .kaze-event-card:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(233,69,96,.18); }
</style>

@code {
    private static readonly string[] _filters = { "Open", "All", "1v1 Duel", "Pool Bet", "My Events" };
    private string _filter = "Open";
    private List<Event> _events = new();
    private bool _loading = true;
    private string _userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        await LoadAsync();
    }

    private async Task SetFilter(string f)
    {
        _filter = f;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var all = _filter switch
        {
            "Open"     => await EventService.GetEventsAsync(status: EventStatus.Open),
            "1v1 Duel" => await EventService.GetEventsAsync(type: EventType.OneVsOne),
            "Pool Bet" => await EventService.GetEventsAsync(type: EventType.Pool),
            _          => await EventService.GetEventsAsync()
        };

        _events = _filter == "My Events"
            ? all.Where(e => e.CreatorId == _userId).ToList()
            : all;

        _loading = false;
    }

    private static string StatusBadge(EventStatus s) => s switch
    {
        EventStatus.Open      => "bg-success",
        EventStatus.Active    => "bg-info text-dark",
        EventStatus.Completed => "bg-secondary",
        EventStatus.Cancelled => "bg-warning text-dark",
        EventStatus.Disputed  => "bg-danger",
        _                     => "bg-secondary"
    };
}
